        "import random\n",
        "\n",
        "var = random.randint(0,4)\n",
        "\n",
        "if var%3  == 0:\n",
        "    print(\"Fizz\")\n",
        "if var%3 == 0:\n",
        "    print(\"Buzz\")\n",
        "if var%3 == 0 and var%5 == 0:\n",
        "    print(\"FizzBuzz\")\n",
        "if var%3 != 0 and var%5 != 0:\n",
        "    print(FizzBuzz)\n",
        "else:\n",
        "    print(var)\n",
        "\n"
      ],
